algoritmo "Calculo_area_do_retângulo"
// Função : Calcular a area de um retângulo
// Autor : Orlando Namba
// Data : 02/03/2026
var
   base, altura, area: real
inicio
   escreva("Informe o valor da base: ")
   leia(base)
   escreva("Informe o valor da altura: ")
   leia(altura)
   
   area <- base * altura
   
   escreva("A área do retângulo é:")
   escreva(area)
fimalgoritmo
