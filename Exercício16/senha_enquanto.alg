algoritmo "senha_enquanto"
// Função : Pedir senha até acertar
// Autor : Orlando Namba
// Data : 16/03/2026
var
   senha: inteiro
inicio
   escreva("Digite a senha: ")
   leia(senha)

   enquanto senha <> 1234 faca
      escreval("Senha incorreta")
      escreva("Digite a senha novamente: ")
      leia(senha)
   fimenquanto

   escreval("Acesso permitido")
fimalgoritmo
